@{
    ViewData["Title"] = "Home Page";
}


<!--Timer selectors pill navbar-->
<nav class="pill-navbar glass">
    <ul class="pill-navbar-list">
        <li class="nav-li">
            <button class="nav-button" id="study-button">
                <i class="bi bi-book"></i>
                Study
            </button>
        </li>

        <li class="nav-li">
            <button class="nav-button" id="short-break-button">
                <i class="bi bi-slash-circle"></i>
                Short Break
            </button>
        </li>

        <li class="nav-li">
            <button class="nav-button" id="long-break-button">
                <i class="bi bi-slash-circle-fill"></i>
                Long Break
            </button>
        </li>
    </ul>
</nav>

<section class="timer-card glass">
    <button id="button-add-widget" class="">
        <i class="bi bi-plus-circle"></i>
    </button>

    <div class="timer-clock">

        <div class="skill">
            <div class="outer">
                <div class="inner">
                    <div id="timer-time">
                       00:00
                    </div>
                </div>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" version="1.1" width="351px" height="351px">
                <defs>
                    <linearGradient id="GradientColor">
                        <stop offset="0%" stop-color="#e91e63" />
                        <stop offset="100%" stop-color="#673ab7" />
                    </linearGradient>
                </defs>
                <circle cx="175.5" cy="175.5" r="165.5" stroke-linecap="round" />
            </svg>
        </div>

    </div>

    <div class="timer-controllers">
        <button class="timer-button" id="restart">
            <i class="bi bi-arrow-clockwise"></i>
            Restart
        </button>

        <button class="timer-button" id="start-stop">
            <i class="bi bi-play-fill"></i>
            Start
        </button>
    </div>
</section>
.skill{
    width: 351px;
    height: 351px;
    position: relative;
}

.outer {
    width: 351px;
    height: 351px;
    border: 1px solid var(--fontss);
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: var(--fontss);
}

.inner {
    width: 300px;
    height: 300px;
    border: 1px solid var(--fontss);
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: var(--fake-glass-green);
}

#timer-time {
    font-weight: 600;
    font-family: 'Karantina', sans-serif;
    font-size: 128px;
    color: var(--fontss);
}

svg{
    position: absolute;
    top: 0;
    left: 0;
}
circle {
    fill: none;
    stroke: var(--third-color);
    stroke-width: 20;
    stroke-linecap: round;
    stroke-dasharray: 1040;     
    stroke-dashoffset: 1040;    
    animation: anim 2s linear forwards;
}

@keyframes anim{
    100%{
        stroke-dashoffset: 0;
    }
}